# Hermes Concierge — server-side keys for the /api/chat Netlify Function.
# Set real values in a local .env (gitignored) for `netlify dev`, and in
# Netlify UI → Site settings → Environment variables for production.
# NEVER prefix these with VITE_ — they must stay server-side.

# Required — primary provider (free tier at aistudio.google.com/apikey)
GEMINI_API_KEY=

# Optional — Claude Haiku fallback relay. Leave empty to run Gemini-only;
# the widget degrades gracefully if Gemini is down and no fallback exists.
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown)
# GEMINI_MODEL=gemini-flash-latest   # flip to a Pro model on the paid tier
# CONCIERGE_GLOBAL_CAP=300     # total messages/day, all visitors
# CLAUDE_DAILY_CAP=200         # max Claude fallback calls/day (cost fence)
# CONCIERGE_IP_CAP=40          # messages/day per visitor (hashed IP)
# CONCIERGE_MOCK=              # "1" = canned replies, no keys needed
